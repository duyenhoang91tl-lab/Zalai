{
  "manifest_version": 3,
  "name": "OME Zalo AI Helper",
  "version": "1.7",
  "description": "CS tool for chat.zalo.me - tra cuu khach, goi y AI, dong bo GSheet",
  "permissions": [
    "storage",
    "clipboardWrite",
    "notifications"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.zalo.me/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ]
}