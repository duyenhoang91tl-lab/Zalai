{
  "manifest_version": 3,
  "name": "OME Zalo AI Helper",
  "version": "1.1",
  "description": "Tra cuu lich su khach hang va tao goi y AI khi chat tren Zalo",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://chat.zalo.me/*",
    "https://script.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chat.zalo.me/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
